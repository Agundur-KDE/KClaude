msgid "KClaude Sessions"
msgstr "Sesiones de KClaude"

msgid "Warning sound on prompts"
msgstr "Sonido de aviso en preguntas"

msgid "Region screenshot to clipboard"
msgstr "Captura de región al portapapeles"

msgid "Screenshot a region → clipboard. Paste with Ctrl+V, e.g. into the Claude Code terminal."
msgstr "Captura una región → portapapeles. Pega con Ctrl+V, p. ej. en la terminal de Claude Code."

msgid "5h: %1% (Reset %2)   ·   7d: %3% (Reset %4)"
msgstr "5 h: %1 % (Reinicio %2)   ·   7 d: %3 % (Reinicio %4)"

msgid "No sessions saved yet."
msgstr "Aún no hay sesiones guardadas."

msgid "Name"
msgstr "Nombre"

msgid "Description (optional)"
msgstr "Descripción (opcional)"

msgid "Directory, e.g. ~/projects/KClaude"
msgstr "Directorio, p. ej. ~/projects/KClaude"

msgid "Session ID (from claude --resume)"
msgstr "ID de sesión (de claude --resume)"

msgid "Cancel"
msgstr "Cancelar"

msgid "Save"
msgstr "Guardar"

msgid "Add session"
msgstr "Añadir sesión"

msgid "Settings"
msgstr "Ajustes"

msgid "Default directory for \"New session\""
msgstr "Directorio predeterminado para «Nueva sesión»"

msgid "e.g. ~/projects"
msgstr "p. ej. ~/projects"

msgid "New session"
msgstr "Nueva sesión"

msgid "Set a default directory in Settings first."
msgstr "Primero define un directorio predeterminado en Ajustes."
