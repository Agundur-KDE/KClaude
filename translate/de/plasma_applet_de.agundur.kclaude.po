msgid "KClaude Sessions"
msgstr "KClaude-Sitzungen"

msgid "Warning sound on prompts"
msgstr "Warnton bei Rückfragen"

msgid "Region screenshot to clipboard"
msgstr "Bildschirmausschnitt in Zwischenablage"

msgid "Screenshot a region → clipboard. Paste with Ctrl+V, e.g. into the Claude Code terminal."
msgstr "Bildschirmausschnitt → Zwischenablage. Mit Strg+V einfügen, z. B. ins Claude-Code-Terminal."

msgid "5h: %1% (Reset %2)   ·   7d: %3% (Reset %4)"
msgstr "5 Std.: %1 % (Reset %2)   ·   7 Tage: %3 % (Reset %4)"

msgid "No sessions saved yet."
msgstr "Noch keine Sitzungen gespeichert."

msgid "Name"
msgstr "Name"

msgid "Description (optional)"
msgstr "Beschreibung (optional)"

msgid "Directory, e.g. ~/projects/KClaude"
msgstr "Verzeichnis, z. B. ~/projects/KClaude"

msgid "Session ID (from claude --resume)"
msgstr "Sitzungs-ID (von claude --resume)"

msgid "Cancel"
msgstr "Abbrechen"

msgid "Save"
msgstr "Speichern"

msgid "Add session"
msgstr "Sitzung hinzufügen"

msgid "Settings"
msgstr "Einstellungen"

msgid "Default directory for \"New session\""
msgstr "Standardverzeichnis für „Neue Sitzung“"

msgid "e.g. ~/projects"
msgstr "z. B. ~/projects"

msgid "New session"
msgstr "Neue Sitzung"

msgid "Set a default directory in Settings first."
msgstr "Zuerst ein Standardverzeichnis in den Einstellungen festlegen."
