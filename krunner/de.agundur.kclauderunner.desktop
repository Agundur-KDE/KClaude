[Desktop Entry]
Type=Service
X-KDE-ServiceTypes=Plasma/Runner
Name=KClaude
Comment=Resume a saved Claude Code session — type "kc <name>"
Icon=kclaude
X-KDE-PluginInfo-Name=kclauderunner
X-KDE-PluginInfo-Version=1.0
X-KDE-PluginInfo-License=GPL
X-KDE-PluginInfo-EnabledByDefault=true
X-Plasma-API=DBus
X-Plasma-DBusRunner-Service=de.agundur.kclauderunner
X-Plasma-DBusRunner-Path=/kclauderunner
X-Plasma-Request-Actions-Once=true
X-Plasma-Runner-Min-Letter-Count=2
X-Plasma-Runner-Match-Regex=^kc .+
X-Plasma-Runner-Syntaxes=kc :q:
X-Plasma-Runner-Syntax-Descriptions=Resume or focus a saved KClaude session by name
